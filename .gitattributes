# Ignore build folders and Next.js generated files from GitHub language statistics
.next/* linguist-generated=true
build/* linguist-generated=true
out/* linguist-generated=true

# Ignore React Server Component payloads which GitHub misidentifies as "RouterOS Script"
*.rsc linguist-generated=true

# Treat lockfiles as generated
package-lock.json linguist-generated=true
yarn.lock linguist-generated=true
pnpm-lock.yaml linguist-generated=true
